rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Kullanıcı klasörü - giriş yapmış herkes kendi dosyalarını yükleyebilir
    match /users/{allPaths=**} {
      allow read: if true; // Avatarlar herkese açık
      allow write: if request.auth != null; // Sadece giriş yapmış kullanıcılar
    }
    // Diğer tüm dosyalar - giriş yapmış kullanıcılar okuyabilir/yazabilir
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
